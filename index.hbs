{{!< default}}

<section class="archive-intro">
    <p class="eyebrow">Latest dispatches</p>
    <h1>{{@site.title}}</h1>

    {{#if @site.description}}
        <p>{{@site.description}}</p>
    {{/if}}
</section>

<section class="post-feed">
    {{#foreach posts}}
        {{> post-card}}
    {{/foreach}}
</section>

{{pagination}}
